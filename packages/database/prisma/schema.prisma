datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "./zod"
  config   = "./zod-generator.config.json"
}

model User {
  id                       String                       @id @default(cuid())
  name                     String
  email                    String
  emailVerified            Boolean
  image                    String?
  createdAt                DateTime
  updatedAt                DateTime
  username                 String?
  role                     String?
  banned                   Boolean?
  banReason                String?
  banExpires               DateTime?
  onboardingComplete       Boolean                      @default(false)
  paymentsCustomerId       String?
  locale                   String?
  displayUsername          String?
  twoFactorEnabled         Boolean?
  lastActiveOrganizationId String?
  sessions                 Session[]
  accounts                 Account[]
  passkeys                 Passkey[]
  invitations              Invitation[]
  purchases                Purchase[]
  members                  Member[]
  twofactors               TwoFactor[]
  notifications            Notification[]
  notificationPreferences  UserNotificationPreference[]

  // Notification preferences (S1-02)
  pushEnabled          Boolean  @default(true)
  pushPreferences      Json     @default("{}")
  emailPreferences     Json     @default("{}")
  pushTokens           PushToken[]
  authoredNewsPosts    NewsPost[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  token     String
  createdAt DateTime
  updatedAt DateTime

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  idToken      String?   @db.Text
  expiresAt    DateTime?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime?
  updatedAt DateTime?

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Organization {
  id                 String       @id @default(cuid())
  name               String
  slug               String?
  logo               String?
  createdAt          DateTime
  metadata           String?
  paymentsCustomerId String?
  members            Member[]
  invitations        Invitation[]
  purchases          Purchase[]

  // Racing domain (S1-02)
  horses       Horse[]
  trainers     Trainer[]
  jockeys      Jockey[]
  courses      Course[]
  meetings     Meeting[]
  races        Race[]
  raceEntries  RaceEntry[]
  newsPosts    NewsPost[]
  pushLogs     PushLog[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  // Circle sync lifecycle (S1-02)
  circleMemberId      String?
  circleProvisionedAt DateTime?
  circleStatus        String?

  // Circle notification poller cursor (S6-01)
  circleLastSeenNotificationId String?

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

model Purchase {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  priceId        String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("purchase")
}

enum NotificationTarget {
  IN_APP
  EMAIL
}

enum NotificationType {
  WELCOME
  APP_UPDATE
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  data      Json             @default("{}")
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@map("notification")
}

model UserNotificationPreference {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  target    NotificationTarget
  createdAt DateTime           @default(now())

  @@unique([userId, type, target])
  @@map("user_notification_preference")
}

// ──────────────────────────────────────────────
// Racing domain (S1-02)
// ──────────────────────────────────────────────

enum HorseStatus {
  PRE_TRAINING
  IN_TRAINING
  REHAB
  RETIRED
  SOLD
}

model Horse {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  slug             String
  name             String

  providerEntityId String?
  providerLastSync DateTime?

  status           HorseStatus  @default(IN_TRAINING)

  bio              String?      @db.Text
  trainerNotes     String?      @db.Text
  photos           Json         @default("[]")
  pedigree         Json?
  ownershipBlurb   String?

  circleSpaceId    String?

  trainerId        String?
  trainer          Trainer?     @relation(fields: [trainerId], references: [id])

  sortOrder        Int          @default(0)
  publishedAt      DateTime?

  latestEntryId    String?      @unique
  nextEntryId      String?      @unique

  entries          RaceEntry[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@unique([organizationId, providerEntityId])
  @@index([organizationId, publishedAt])
  @@map("horse")
}

model Trainer {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?
  name             String
  meta             Json?
  horses           Horse[]
  entries          RaceEntry[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, providerEntityId])
  @@index([organizationId, name])
  @@map("trainer")
}

model Jockey {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?
  name             String
  meta             Json?
  entries          RaceEntry[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, providerEntityId])
  @@map("jockey")
}

model Course {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?
  name             String
  country          String?
  surface          String?
  meetings         Meeting[]
  createdAt        DateTime     @default(now())

  @@unique([organizationId, providerEntityId])
  @@map("course")
}

model Meeting {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?
  courseId          String
  course           Course       @relation(fields: [courseId], references: [id])
  date             DateTime
  races            Race[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, providerEntityId])
  @@index([organizationId, date])
  @@map("meeting")
}

model Race {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?

  meetingId        String
  meeting          Meeting      @relation(fields: [meetingId], references: [id])

  postTime         DateTime
  name             String?
  raceType         String?
  distanceFurlongs Int?
  className        String?
  prizeMoney       Int?
  goingDescription String?

  entries          RaceEntry[]

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, providerEntityId])
  @@index([organizationId, postTime])
  @@map("race")
}

enum RaceEntryStatus {
  ENTERED
  DECLARED
  NON_RUNNER
  RAN
  DISQUALIFIED
  VOID
}

model RaceEntry {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerEntityId String?

  horseId          String
  horse            Horse           @relation(fields: [horseId], references: [id], onDelete: Cascade)

  raceId           String
  race             Race            @relation(fields: [raceId], references: [id], onDelete: Cascade)

  status           RaceEntryStatus

  draw             Int?
  weightLbs        Int?
  jockeyId         String?
  jockey           Jockey?         @relation(fields: [jockeyId], references: [id])
  trainerId        String?
  trainer          Trainer?        @relation(fields: [trainerId], references: [id])

  finishingPosition Int?
  beatenLengths    Decimal?        @db.Decimal(5, 2)
  ratingAchieved   Int?
  timeformComment  String?         @db.Text
  performanceRating Int?
  starRating       Int?

  notifiedStates   Json            @default("[]")

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([organizationId, providerEntityId])
  @@index([organizationId, status])
  @@index([horseId, status])
  @@index([raceId])
  @@map("race_entry")
}

// ──────────────────────────────────────────────
// Club content (S1-02)
// ──────────────────────────────────────────────

model NewsPost {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  slug                   String
  title                  String
  subtitle               String?
  featuredImageUrl       String?

  contentJson            Json
  contentHtml            String       @db.Text

  publishedAt            DateTime?
  notifyMembersOnPublish Boolean      @default(false)
  notificationSentAt     DateTime?

  authorUserId           String?
  author                 User?        @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, publishedAt])
  @@map("news_post")
}

// ──────────────────────────────────────────────
// Push infrastructure (S1-02)
// ──────────────────────────────────────────────

enum DevicePlatform {
  IOS
  ANDROID
}

model PushToken {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String         @unique
  deviceLabel   String?
  platform      DevicePlatform
  lastSeenAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([userId])
  @@map("push_token")
}

enum PushTriggerType {
  HORSE_DECLARED
  HORSE_NON_RUNNER
  RACE_RESULT
  TRAINER_POST
  NEWS_POST
  SYSTEM
}

enum PushStatus {
  QUEUED
  SENT
  FAILED
}

model PushLog {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  expoPushToken  String?
  title          String
  body           String
  data           Json?
  triggerType    PushTriggerType
  triggerRefId   String?
  status         PushStatus      @default(QUEUED)
  error          String?
  sentAt         DateTime?
  createdAt      DateTime        @default(now())

  @@index([organizationId, createdAt])
  @@index([triggerType, triggerRefId])
  @@map("push_log")
}

// ──────────────────────────────────────────────
// Stripe webhook idempotency (S1-02)
// ──────────────────────────────────────────────

model StripeEventLog {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([type, processedAt])
  @@map("stripe_event_log")
}

